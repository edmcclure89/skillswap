# SkillSwap Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit your real .env to git

# ── Supabase ──────────────────────────────────────────────────
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Stripe Publishable Key (safe to expose in frontend) ───────
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Stripe Price IDs (get these from Stripe Dashboard > Products)
# Test mode IDs start with price_test_ or just price_
REACT_APP_PRICE_STUDENT=price_xxxxxxxxxxxxxxxxxxxx
REACT_APP_PRICE_PLUS_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
REACT_APP_PRICE_PLUS_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx
REACT_APP_PRICE_ELITE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
REACT_APP_PRICE_ELITE_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx

# ── Your deployed site URL (used as Stripe redirect base) ─────
# For local dev: http://localhost:3000
# For production: https://your-vercel-domain.vercel.app
REACT_APP_SITE_URL=http://localhost:3000
