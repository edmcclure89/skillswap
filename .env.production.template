# SkillSwap — Production Environment Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git — it's in .gitignore.
# Set these same variables in Vercel: Settings > Environment Variables
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Stripe (Developers > API Keys — use LIVE key for production)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY

# ─────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — set in Vercel env vars, never in VITE_ prefix
# These are used by the /api/webhook serverless function only.
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
